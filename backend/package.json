  "private": true,
  "description": "Automated editorial scraping, Claude-powered grammar analysis, and FCM push.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
