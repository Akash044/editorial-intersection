# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database (PostgreSQL) ---
# Local: postgresql://postgres:password@localhost:5432/editorial_intersection
# Railway: copy the DATABASE_URL Railway exposes for the Postgres plugin
DATABASE_URL="postgresql://postgres:password@localhost:5432/editorial_intersection"

# --- Google Gemini ---
# Get free from https://aistudio.google.com/apikey (just a Google login)
GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXX
# gemini-2.5-flash = fast + cheap + generous free tier
# gemini-2.5-pro   = best quality (slower, lower free tier limits)
GEMINI_MODEL=gemini-2.5-flash

# --- Pipeline ---
# Cron expression (UTC). Default: 6:00 AM Asia/Dhaka = 00:00 UTC
PIPELINE_CRON="0 0 * * *"
PIPELINE_TIMEZONE="Asia/Dhaka"
# Cap articles per source per run to control API cost during testing
MAX_ARTICLES_PER_SOURCE=2
MAX_SENTENCES_PER_ARTICLE=15

# --- Firebase Cloud Messaging ---
# Path to service account JSON downloaded from Firebase console
# Or set FIREBASE_SERVICE_ACCOUNT_JSON to the raw JSON (useful for Railway env vars)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Feature flags ---
ENABLE_NOTIFICATIONS=false
